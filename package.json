{
  "name": "shortcut-menu-bar",
  "displayName": "Shortcut Menu Bar",
  "description": "Add handy buttons like beautify, show opened files, save, toggle terminal, activity bar etc to editor menu bar. User-defined buttons are also possible.",
  "version": "3.0.6",
  "publisher": "jerrygoyal",
  "author": {
    "name": "Gourav Goyal"
  },
  "engines": {
    "vscode": "^1.65.0"
  },
  "license": "GPL-3.0-or-later",
  "icon": "images/menubar.png",
  "galleryBanner": {
    "color": "#752d00",
    "theme": "dark"
  },
  "bugs": {
    "url": "https://github.com/GorvGoyl/Shortcut-Menu-Bar-VSCode-Extension/issues",
    "email": "hey@gourav.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GorvGoyl/Shortcut-Menu-Bar-VSCode-Extension.git"
  },
  "homepage": "https://github.com/GorvGoyl/Shortcut-Menu-Bar-VSCode-Extension",
  "categories": [
    "Programming Languages",
    "Other",
    "Visualization"
  ],
  "keywords": [
    "shortcut",
    "toolbar",
    "shortcuts",
    "menu",
    "menubar",
    "tool",
    "status",
    "editor",
    "bar",
    "shortcut menu bar",
    "button"
  ],
  "activationEvents": [
    "onCommand:ShortcutMenuBar.navigateBack",
    "onCommand:ShortcutMenuBar.navigateForward",
    "onCommand:ShortcutMenuBar.switchHeaderSource",
    "onCommand:ShortcutMenuBar.save",
    "onCommand:ShortcutMenuBar.beautify",
    "onCommand:ShortcutMenuBar.toggleRenderWhitespace",
    "onCommand:ShortcutMenuBar.openFilesList",
    "onCommand:ShortcutMenuBar.toggleTerminal",
    "onCommand:ShortcutMenuBar.toggleActivityBar",
    "onCommand:ShortcutMenuBar.quickOpen",
    "onCommand:ShortcutMenuBar.findReplace",
    "onCommand:ShortcutMenuBar.undo",
    "onCommand:ShortcutMenuBar.redo",
    "onCommand:ShortcutMenuBar.commentLine",
    "onCommand:ShortcutMenuBar.saveAll",
    "onCommand:ShortcutMenuBar.formatWith",
    "onCommand:ShortcutMenuBar.openFile",
    "onCommand:ShortcutMenuBar.newFile",
    "onCommand:ShortcutMenuBar.goToDefinition",
    "onCommand:ShortcutMenuBar.cut",
    "onCommand:ShortcutMenuBar.copy",
    "onCommand:ShortcutMenuBar.paste",
    "onCommand:ShortcutMenuBar.compareWithSaved",
    "onCommand:ShortcutMenuBar.showCommands",
    "onCommand:ShortcutMenuBar.startDebugging",
    "onCommand:ShortcutMenuBar.indentLines",
    "onCommand:ShortcutMenuBar.outdentLines",
    "onCommand:ShortcutMenuBar.openSettings",
    "onCommand:ShortcutMenuBar.toggleWordWrap",
    "onCommand:ShortcutMenuBar.changeEncoding",
    "onCommand:ShortcutMenuBar.powershellRestartSession",
    "onCommand:ShortcutMenuBar.userButton10",
    "onCommand:ShortcutMenuBar.userButton01",
    "onCommand:ShortcutMenuBar.userButton02",
    "onCommand:ShortcutMenuBar.userButton03",
    "onCommand:ShortcutMenuBar.userButton04",
    "onCommand:ShortcutMenuBar.userButton05",
    "onCommand:ShortcutMenuBar.userButton06",
    "onCommand:ShortcutMenuBar.userButton07",
    "onCommand:ShortcutMenuBar.userButton08",
    "onCommand:ShortcutMenuBar.userButton09",
    "onCommand:ShortcutMenuBar.codeFold",
    "onCommand:ShortcutMenuBar.codeUnfold",
    "onCommand:ShortcutMenuBar.plantUmlPreview",
    "onCommand:ShortcutMenuBar.toggleMaximizeEditorGroup"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": [
      {
        "title": "Shortcut Menu Bar configuration",
        "properties": {
          "ShortcutMenuBar.buttons": {
            "type": "array",
            "default": [
              {
                "command": "ShortcutMenuBar.navigateBack",
                "show": true,
                "name": "Navigate back",
                "order": 2
              },
              {
                "command": "ShortcutMenuBar.navigateForward",
                "show": true,
                "name": "Navigate forward",
                "order": 3
              },
              {
                "command": "ShortcutMenuBar.switchHeaderSource",
                "show": false,
                "name": "Switch Header/Source",
                "order": 1,
                "when": "editorTextFocus"
              },
              {
                "command": "ShortcutMenuBar.save",
                "show": false,
                "name": "Save",
                "order": 4,
                "when": "!isInDiffEditor && !markdownPreviewFocus"
              },
              {
                "command": "ShortcutMenuBar.beautify",
                "show": true,
                "name": "Beautify",
                "order": 5,
                "when": "!isInDiffEditor && !markdownPreviewFocus"
              },
              {
                "command": "ShortcutMenuBar.toggleRenderWhitespace",
                "show": false,
                "name": "Toggle render whitespace",
                "order": 6
              },
              {
                "command": "ShortcutMenuBar.openFilesList",
                "show": true,
                "name": "Show opened files list",
                "order": 7,
                "when": "!isInDiffEditor && !markdownPreviewFocus"
              },
              {
                "command": "ShortcutMenuBar.toggleTerminal",
                "show": true,
                "name": "Toggle terminal",
                "order": 8
              },
              {
                "command": "ShortcutMenuBar.toggleActivityBar",
                "show": false,
                "name": "Toggle activity bar",
                "order": 9
              },
              {
                "command": "ShortcutMenuBar.quickOpen",
                "show": false,
                "name": "Quick open",
                "order": 10
              },
              {
                "command": "ShortcutMenuBar.findReplace",
                "show": false,
                "name": "Find replace",
                "order": 11
              },
              {
                "command": "ShortcutMenuBar.undo",
                "show": false,
                "name": "Undo",
                "order": 12,
                "when": "textInputFocus && !editorReadonly"
              },
              {
                "command": "ShortcutMenuBar.redo",
                "show": false,
                "name": "Redo",
                "order": 13,
                "when": "textInputFocus && !editorReadonly"
              },
              {
                "command": "ShortcutMenuBar.commentLine",
                "show": false,
                "name": "Toggle line comment",
                "order": 14,
                "when": "editorTextFocus && !editorReadonly"
              },
              {
                "command": "ShortcutMenuBar.saveAll",
                "show": false,
                "name": "Save all",
                "order": 15
              },
              {
                "command": "ShortcutMenuBar.formatWith",
                "show": false,
                "name": "Format document with..",
                "order": 16,
                "when": "!isInDiffEditor && !markdownPreviewFocus"
              },
              {
                "command": "ShortcutMenuBar.openFile",
                "show": false,
                "name": "Open file",
                "order": 17
              },
              {
                "command": "ShortcutMenuBar.newFile",
                "show": false,
                "name": "New file",
                "order": 18
              },
              {
                "command": "ShortcutMenuBar.goToDefinition",
                "show": false,
                "name": "Go to definition",
                "order": 19,
                "when": "editorHasDefinitionProvider && editorTextFocus && !isInEmbeddedEditor"
              },
              {
                "command": "ShortcutMenuBar.cut",
                "show": false,
                "name": "Cut",
                "order": 20
              },
              {
                "command": "ShortcutMenuBar.copy",
                "show": false,
                "name": "Copy",
                "order": 21
              },
              {
                "command": "ShortcutMenuBar.paste",
                "show": false,
                "name": "Paste",
                "order": 22
              },
              {
                "command": "ShortcutMenuBar.compareWithSaved",
                "show": false,
                "name": "Compare with saved",
                "order": 23
              },
              {
                "command": "ShortcutMenuBar.showCommands",
                "show": false,
                "name": "Open command pallet",
                "order": 24
              },
              {
                "command": "ShortcutMenuBar.startDebugging",
                "show": false,
                "name": "Start debugging",
                "order": 25,
                "when": "debuggersAvailable && !inDebugMode"
              },
              {
                "command": "ShortcutMenuBar.indentLines",
                "show": false,
                "name": "Indent lines",
                "order": 26
              },
              {
                "command": "ShortcutMenuBar.outdentLines",
                "show": false,
                "name": "Outdent lines",
                "order": 27
              },
              {
                "command": "ShortcutMenuBar.openSettings",
                "show": false,
                "name": "open settings",
                "order": 28
              },
              {
                "command": "ShortcutMenuBar.toggleWordWrap",
                "show": false,
                "name": "Toggle word wrap",
                "order": 29
              },
              {
                "command": "ShortcutMenuBar.changeEncoding",
                "show": false,
                "name": "Change file encoding",
                "order": 30
              },
              {
                "command": "ShortcutMenuBar.powershellRestartSession",
                "show": false,
                "name": "Restart PowerShell session",
                "order": 31
              },
              {
                "command": "ShortcutMenuBar.toggleMaximizeEditorGroup",
                "show": false,
                "name": "Toggle Maximize Editor Group",
                "order": 32
              },
              {
                "command": "ShortcutMenuBar.codeFold",
                "show": false,
                "name": "Code fold",
                "order": 40
              },
              {
                "command": "ShortcutMenuBar.codeUnfold",
                "show": false,
                "name": "Code unfold",
                "order": 41
              },
              {
                "command": "ShortcutMenuBar.plantUmlPreview",
                "show": false,
                "name": "PlantUML Preview",
                "order": 42,
                "when": "resourceExtname =~ /^.wsd$|^.pu$|^.puml$|^.plantuml$|^.iuml$/"
              }
            ],
            "description": "Configure the shortcut menu bar buttons (both built-in and custom).",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "The title of the button"
                },
                "command": {
                  "type": "string",
                  "description": "The VS Code command to execute"
                },
                "icon": {
                  "type": "string",
                  "description": "The codicon or path for the button"
                },
                "show": {
                  "type": "boolean",
                  "description": "Should the button be shown?"
                },
                "order": {
                  "type": "number",
                  "description": "The order index"
                },
                "alwaysVisible": {
                  "type": "boolean",
                  "description": "If false, the button might collapse into the ... menu"
                },
                "when": {
                  "type": "string",
                  "description": "Context condition to show the button"
                }
              }
            }
          }
        }
      }
    ],
    "commands": [
      {
        "command": "ShortcutMenuBar.navigateBack",
        "title": "Navigate back",
        "category": "ShortcutMenuBar",
        "icon": "$(goto-previous-location)"
      },
      {
        "command": "ShortcutMenuBar.navigateForward",
        "title": "Navigate forward",
        "category": "ShortcutMenuBar",
        "icon": "$(goto-next-location)"
      },
      {
        "command": "ShortcutMenuBar.beautify",
        "title": "Beautify",
        "category": "ShortcutMenuBar",
        "icon": "$(json)"
      },
      {
        "command": "ShortcutMenuBar.openFilesList",
        "title": "Show opened files list",
        "category": "ShortcutMenuBar",
        "icon": "$(list-unordered)"
      },
      {
        "command": "ShortcutMenuBar.toggleTerminal",
        "title": "Toggle terminal",
        "category": "ShortcutMenuBar",
        "icon": "$(terminal)"
      }
    ],
    "keybindings": [
      {
        "command": "ShortcutMenuBar.userButton01",
        "key": "ctrl+alt+1",
        "mac": "shift+cmd+1"
      },
      {
        "command": "ShortcutMenuBar.userButton02",
        "key": "ctrl+alt+2",
        "mac": "shift+cmd+2"
      },
      {
        "command": "ShortcutMenuBar.userButton03",
        "key": "ctrl+alt+3",
        "mac": "shift+cmd+3"
      },
      {
        "command": "ShortcutMenuBar.userButton04",
        "key": "ctrl+alt+4",
        "mac": "shift+cmd+4"
      },
      {
        "command": "ShortcutMenuBar.userButton05",
        "key": "ctrl+alt+5",
        "mac": "shift+cmd+5"
      },
      {
        "command": "ShortcutMenuBar.userButton06",
        "key": "ctrl+alt+6",
        "mac": "shift+cmd+6"
      },
      {
        "command": "ShortcutMenuBar.userButton07",
        "key": "ctrl+alt+7",
        "mac": "shift+cmd+7"
      },
      {
        "command": "ShortcutMenuBar.userButton08",
        "key": "ctrl+alt+8",
        "mac": "shift+cmd+8"
      },
      {
        "command": "ShortcutMenuBar.userButton09",
        "key": "ctrl+alt+9",
        "mac": "shift+cmd+9"
      },
      {
        "command": "ShortcutMenuBar.userButton10",
        "key": "ctrl+alt+0",
        "mac": "shift+cmd+0"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ShortcutMenuBar.navigateBack",
          "group": "1_navigation@2"
        },
        {
          "command": "ShortcutMenuBar.navigateForward",
          "group": "1_navigation@3"
        },
        {
          "command": "ShortcutMenuBar.beautify",
          "group": "1_navigation@5",
          "when": "!isInDiffEditor && !markdownPreviewFocus"
        },
        {
          "command": "ShortcutMenuBar.openFilesList",
          "group": "1_navigation@7",
          "when": "!isInDiffEditor && !markdownPreviewFocus"
        },
        {
          "command": "ShortcutMenuBar.toggleTerminal",
          "group": "1_navigation@8"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "login": "vsce login jerrygoyal",
    "publish": "vsce publish",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/node": "^17.0.23",
    "@types/vscode": "^1.65.0",
    "@typescript-eslint/eslint-plugin": "^5.16.0",
    "@typescript-eslint/parser": "^5.16.0",
    "eslint": "^8.12.0",
    "glob": "^7.2.0",
    "typescript": "^4.6.3",
    "vsce": "^2.7.0"
  }
}